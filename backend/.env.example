# ==========================================
# Knowify Environment Configuration Template
# ==========================================

# API General Configuration
PROJECT_NAME="Knowify RAG Chatbot API"
PORT=8000

# JWT Security Configuration
# WARNING: Change JWT_SECRET to a secure random key in production!
JWT_SECRET="super_secret_signing_key_change_me_in_production"
JWT_ALGORITHM="HS256"
# Optional: Set dynamic JWKS key issuer URL for Clerk/Supabase Auth verification
# JWT_ISSUER_URL="https://clerk.yourdomain.com"

# LLM & Third-Party APIs
# Replace with active OpenAI/Tavily API keys to enable live responses and web search
LLM_API_KEY="placeholder_key"
TAVILY_API_KEY="placeholder_key"

# Vector Database (Qdrant)
# QDRANT_MODE options: "local" (uses SQLite-backed local directory) or "docker" (networked vector database)
QDRANT_MODE="local"
QDRANT_URL="http://localhost:6333"
QDRANT_LOCAL_PATH="data/qdrant_local"

# Caching & Session Store (Redis)
# CACHE_MODE options: "memory" (thread-safe local dict) or "redis" (active Redis caching service)
CACHE_MODE="memory"
REDIS_URL="redis://localhost:6379/0"
